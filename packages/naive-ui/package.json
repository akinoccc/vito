{
  "name": "@uozi/vito-naive-ui",
  "version": "0.1.5",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/akinoccc/vito.git",
    "directory": "packages/naive-ui"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/vito-naive-ui.css"
  ],
  "scripts": {
    "build": "rimraf dist && vite build"
  },
  "peerDependencies": {
    "@uozi/vito-core": "^0.1.1",
    "naive-ui": "^2.43.2",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@uozi/vito-core": "workspace:*",
    "vite-plugin-dts": "^4.5.4",
    "vue-router": "^4.6.0"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      },
      "./vito-naive-ui.css": "./dist/vito-naive-ui.css"
    }
  }
}
